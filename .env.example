# BuildMore frontend environment example
# Set these in Vercel. Never commit real secrets in .env.local.

NEXT_PUBLIC_API_BASE_URL=https://api.buildmore.co.kr
NEXT_PUBLIC_ADMIN_API_URL=https://api.buildmore.co.kr
BACKEND_URL=https://api.buildmore.co.kr

# Server-side Next.js route handlers use these for internal backend calls.
INTERNAL_API_KEY=replace_with_backend_internal_api_key
ADMIN_INTERNAL_KEY=replace_with_backend_internal_api_key
ADMIN_TOKEN=replace_with_admin_ui_token

# Browser/public keys
NEXT_PUBLIC_KAKAO_MAP_KEY=
KAKAO_MAP_API_KEY=

# BuildMore map tile delivery
# During R2 development, use the public r2.dev base URL.
# In production, replace with the R2 custom domain such as https://tiles.buildmore.co.kr.
NEXT_PUBLIC_MAP_ENGINE=maplibre
NEXT_PUBLIC_MAP_TILES_BASE_URL=
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_MAP_TILESET_VERSION=dev

# Only needed if the frontend VWorld proxy remains enabled.
VWORLD_API_KEY=
VWORLD_DOMAIN=https://buildmore.co.kr
VWORLD_PROXY_TOKEN=
